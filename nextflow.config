// ResistAI Nextflow Configuration

manifest {
    name        = 'ResistAI'
    author      = 'Kagan Saglam'
    description = 'Antibiotic resistance protein structural analysis pipeline'
    version     = '1.0.0'
    nextflowVersion = '>=25.0.0'
}

// Default parameters
params {
    outdir    = 'results'
    max_cpus  = 8
    max_memory = '32.GB'
    max_time   = '24.h'
}
// Default process settings
process {
    cpus   = 2
    memory = '4.GB'
    time   = '2.h'

    withName: 'FETCH_CARD' {
        cpus   = 1
        memory = '2.GB'
        time   = '1.h'
    }

    withName: 'RUN_ESMFOLD' {
        cpus   = 4
        memory = '16.GB'
        time   = '6.h'
    }

    withName: 'FIND_POCKETS' {
        cpus   = 2
        memory = '4.GB'
        time   = '2.h'
    }
withName: 'SUMMARY_REPORT' {
        cpus   = 1
        memory = '2.GB'
        time   = '30.m'
    }
}

// Profiles
profiles {
// Local execution (default)
    standard {
        process.executor = 'local'
        docker.enabled   = false
    }

    // Docker profile
    docker {
        process.executor = 'local'
        docker.enabled   = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    // HPC — SLURM
    slurm {
        process.executor = 'slurm'
        process.queue    = 'normal'
        docker.enabled   = false
        singularity.enabled   = true
        singularity.autoMounts = true
    }

// HPC — LSF (EBI uses LSF)
    lsf {
        process.executor = 'lsf'
        process.queue    = 'research'
        docker.enabled   = false
        singularity.enabled   = true
        singularity.autoMounts = true
    }

    // Test profile — small dataset
    test {
        params.outdir = 'test_results'
        process {
            cpus   = 1
            memory = '2.GB'
            time   = '30.m'
        }
    }
}
// Execution reports
report {
    enabled = true
    file    = "${params.outdir}/pipeline_report.html"
}

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_timeline.html"
}

dag {
    enabled = true
    file    = "${params.outdir}/pipeline_dag.html"
}
